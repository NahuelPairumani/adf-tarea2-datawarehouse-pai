{
	"name": "df_bronze_catalogo_establecimientos",
	"properties": {
		"folder": {
			"name": "bronze"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "catalogo_establecimientos_csv",
						"type": "DatasetReference"
					},
					"name": "source1"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "silver_establecimientos",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "derivedColumn1"
				},
				{
					"name": "filter1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          establecimiento_id as string,",
				"          nombre_establecimiento as string,",
				"          tipo_establecimiento as string,",
				"          nivel_atencion as short,",
				"          zona as string,",
				"          sedes as string,",
				"          red_salud as string,",
				"          departamento as string,",
				"          municipio as string,",
				"          latitud as string,",
				"          longitud as string,",
				"          tiene_cadena_frio as boolean,",
				"          activo as boolean",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> source1",
				"source1 derive(establecimiento_id = trim(establecimiento_id),",
				"          nombre_establecimiento = trim(nombre_establecimiento),",
				"          tipo_establecimiento = trim(tipo_establecimiento),",
				"          zona = trim(zona),",
				"          sedes = trim(sedes),",
				"          red_salud = trim(red_salud),",
				"          departamento = trim(departamento),",
				"          municipio = trim(municipio),",
				"          latitud = iif(size(split(latitud, '.')) == 3, \r",
				"    toDecimal(split(latitud, '.')[1] + '.' + split(latitud, '.')[2] + split(latitud, '.')[3], 12, 9), \r",
				"    toDecimal(latitud, 12, 9)\r",
				"),",
				"          longitud = iif(size(split(longitud, '.')) == 3, \r",
				"    toDecimal(split(longitud, '.')[1] + '.' + split(longitud, '.')[2] + split(longitud, '.')[3], 12, 9), \r",
				"    toDecimal(longitud, 12, 9)\r",
				"),",
				"          nivel_atencion = toInteger(nivel_atencion)) ~> derivedColumn1",
				"derivedColumn1 filter(!isNull(establecimiento_id) && !isNull(nombre_establecimiento) && !isNull(tipo_establecimiento) && !isNull(nivel_atencion) && !isNull(zona) && !isNull(sedes) && !isNull(red_salud) && !isNull(departamento) && !isNull(municipio) && !isNull(latitud) && !isNull(longitud) && !isNull(tiene_cadena_frio) && !isNull(activo)) ~> filter1",
				"filter1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          establecimiento_id as string,",
				"          nombre_establecimiento as string,",
				"          tipo_establecimiento as string,",
				"          nivel_atencion as integer,",
				"          zona as string,",
				"          sedes as string,",
				"          red_salud as string,",
				"          latitud as decimal(12,9),",
				"          longitud as decimal(12,9),",
				"          tiene_cadena_frio as boolean,",
				"          activo as boolean",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          establecimiento_id,",
				"          nombre_establecimiento,",
				"          tipo_establecimiento,",
				"          nivel_atencion,",
				"          zona,",
				"          sedes,",
				"          red_salud,",
				"          latitud,",
				"          longitud,",
				"          tiene_cadena_frio,",
				"          activo",
				"     )) ~> sink1"
			]
		}
	}
}